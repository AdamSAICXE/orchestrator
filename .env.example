# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_USER_ID=7247320175

# Sub-agents
ZOHO_AGENT_URL=https://zoho-agent-production.up.railway.app
ZOHO_AGENT_TOKEN=your_zoho_agent_rest_token
MOTION_AGENT_URL=https://motion-agent-production.up.railway.app
MOTION_AGENT_TOKEN=your_motion_agent_rest_token

# PostgreSQL — Railway sets this automatically when you add the plugin
DATABASE_URL=postgresql://...

# Server
PORT=3000

# -----------------------------------------------------------------------
# IMPORTANT: On your Zoho agent Railway deployment, set:
#   AGENT_REQUIRE_APPROVAL=false
# The orchestrator is the approval layer — the Zoho agent should not
# double-prompt. Without this, Zoho write operations will be auto-denied.
# -----------------------------------------------------------------------
